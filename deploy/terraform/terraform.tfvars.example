aws_region = "ap-southeast-1"
table_name = "medallion-interlock"

# Globally unique S3 bucket name (leave empty for auto-generated)
# bucket_name = ""

# Lambda settings
# lambda_memory_size = 256
# lambda_timeout     = 300
# log_retention_days = 7

# Interlock settings
# readiness_ttl = "1h"
# retention_ttl = "168h"

# Evaluator URL (leave empty to auto-wire to API Gateway)
# evaluator_base_url = ""

# Glue settings
# glue_worker_type     = "G.1X"
# glue_number_workers  = 2
# glue_timeout_minutes = 30

# Ingestion rates (minutes)
# wikipedia_rate_minutes = 5
# gharchive_rate_minutes = 60
# openmeteo_rate_minutes = 60

# Trigger permissions
# enable_glue_trigger = true

# Set to false to retain DynamoDB/S3 on destroy
# destroy_on_delete = true
